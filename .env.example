BOT_TOKEN=
# Bot logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
# Optional (Railway worker): sleep N seconds before Telegram getUpdates — reduces Conflict when old and new
# containers overlap during deploy. On Railway, if you omit this variable, the bot waits ~18 s by default.
# Set BOT_POLLING_START_DELAY_SECONDS=0 to disable that default. Try 25–40 if Conflict persists after deploy.
# BOT_POLLING_START_DELAY_SECONDS=15
# Retries during PTB bootstrap (delete_webhook etc.). Integer, default 10 if unset.
# BOT_POLLING_BOOTSTRAP_RETRIES=10
# Throttle identical getUpdates Conflict warnings in logs (seconds, min 30, default 300).
# BOT_CONFLICT_LOG_INTERVAL_SECONDS=300
# Telegram user id who receives /start visitor alerts (bot owner)
OWNER_TELEGRAM_ID=7846059164
# Comma-separated Telegram user ids allowed to use /admin (catalog + Stripe tools). Others get "Access denied".
# ADMIN_IDS=123456789,987654321
ADMIN_IDS=
# Same Telegram user id(s) pattern: developer who may run /health alongside the owner (default 7973899604)
DEVELOPER_TELEGRAM_ID=7973899604
STRIPE_SECRET_KEY=sk_live_xxx_or_sk_test_xxx
# Optional alias for admin Stripe automation (if set, has priority over STRIPE_SECRET_KEY)
STRIPE_API_KEY=
# Optional: sync sales_log JSON to Railway Variables after each sale (off by default)
ENABLE_SALES_LOG_RAILWAY_SYNC=0
# Railway GraphQL credentials for SALES_LOG_JSON sync (required only if ENABLE...=1)
RAILWAY_API_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_ENVIRONMENT_ID=
RAILWAY_SERVICE_ID=
# Webhook signing secret (Stripe Dashboard). Strongly recommended for /webhook in production.
STRIPE_WEBHOOK_SECRET=whsec_xxx
BACKEND_URL=http://localhost:5000
DOMAIN=http://localhost:5000
# Stripe cancel/success URLs must include a scheme. In production use https://… (bare musicacupuncture.digital is auto-fixed to https:// in code, but prefer full URLs in .env).
# Telegram Mini App: полный HTTPS URL (или оставь пустым и задай только DOMAIN с https://)
# Прод (Railway + свой домен): MINIAPP_URL=https://musicacupuncture.digital/miniapp.html
# Railway без своего домена: MINIAPP_URL=https://your-service.up.railway.app/miniapp.html
# GitHub Pages (только витрина): MINIAPP_URL=https://USER.github.io/REPO/miniapp.html
MINIAPP_URL=
# CORS: origins allowed to call API from browser (comma-separated). На проде также подхватываются DOMAIN и BACKEND_URL.
# Явно укажи, если сайт на другом домене, чем BACKEND_URL, или нужен www отдельно:
# MINIAPP_CORS_ORIGINS=https://musicacupuncture.digital,https://www.musicacupuncture.digital
# Если DOMAIN=https://musicacupuncture.digital — этот origin разрешится и без этой переменной.
MINIAPP_CORS_ORIGINS=
# Полный HTTPS к website.html после оплаты с сайта (например GitHub Pages). Если пусто — сервер: BACKEND_URL + /website.html (тот же хост, что API).
# WEBSITE_SUCCESS_URL=https://USER.github.io/REPO/website.html
# Optional: same value sent in WebApp URL ?checkout_secret= and header X-Miniapp-Checkout-Secret for track_id checkouts only.
MINIAPP_CHECKOUT_SECRET=
# Stripe Checkout line amount in öre when currency=sek (default 16900 = 169 SEK).
CHECKOUT_SEK_UNIT_AMOUNT=16900
# Optional: redirect URL after successful Stripe checkout (use Telegram bot link to return focus to Telegram app).
# Example: CHECKOUT_SUCCESS_URL=https://t.me/musicacupuncture_bot
CHECKOUT_SUCCESS_URL=

# Telegram Payments (Stripe): provider token from BotFather (needed for /buy → "Pay inside Telegram")
PAYMENTS_PROVIDER_TOKEN=
# Invoice currency for Telegram Payments (should match Stripe Checkout currency)
PAYMENTS_CURRENCY=USD
# JSON map stem/name → Telegram file_id (output of `python upload_songs.py`). Paste full JSON as one line or multiline in Railway Variables.
# Keys must match upload_songs.py (audio filename without .mp3). Do not commit real file_ids.json to Git.
# FILE_IDS_JSON={"Divine sound Vitamins from God":"AgAC..."}
# Новый трек 17: добавьте пару "Divine sound Sleep Best Silver Power from God":"<file_id>" после python upload_songs.py

# Google Drive (рекомендуется для MP3 >20 MB на сайте после Stripe):
# 1) Google Cloud Console → проект → APIs & Services → Enable "Google Drive API"
# 2) IAM → Service Accounts → Create → Keys → JSON → сохранить файл вне Git
# 3) В Google Drive: папка с MP3 → Share → добавить client_email из JSON (роль Viewer)
# 4) ID файла: откройте MP3 в Drive → URL содержит /file/d/FILE_ID/view — или Drive API list
# GOOGLE_SERVICE_ACCOUNT_JSON=secrets/google-service-account.json
# Railway: можно вставить весь JSON ключа одной строкой (без файла в контейнере):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
#
# pCloud (запасной вариант, если My Apps недоступен):
# PCLOUD_AUTH_TOKEN=xxxxxxxx
# Как узнать fileid: в веб-клиенте откройте папку с MP3; надёжный способ — API listfolder (см. docs.pcloud.com) — в ответе у каждого файла поле fileid.
# Локально: положите MP3 в одну папку в pCloud, задайте PCLOUD_AUTH_TOKEN в .env и выполните:
#   python scripts/pcloud_build_catalog_snippet.py --folder-id <ID> --merge songs/catalog.json
# Для EU-региона часто нужен: PCLOUD_API_HOST=eapi.pcloud.com
# PCLOUD_API_HOST=api.pcloud.com
# Примечание: https://api.pcloud.com/ в браузере часто даёт 404 — это нормально (нет «главной страницы» API).
# Вызовы только с именем метода, например: .../listfolder?auth=TOKEN&folderid=0
# Если My Apps / «Ny App» показывает Temporary unavailable — проблема или лимит на стороне pCloud: другой браузер,
# вход владельцем семейного аккаунта, позже повторить или support@pcloud.com

# Folder under project root with audio files for sale (default: songs)
AUDIO_SALES_DIR=songs
# Default price (USD, whole dollars) for each file in that folder unless overridden in songs/catalog.json
DEFAULT_TRACK_PRICE_USD=16
# Опционально: общий тестовый Payment Link для всех треков (website fallback + tracks.TRACKS при TEST_MODE=true)
TEST_PAYMENT_LINK=
# TEST_MODE: reduced prices + [TEST] labels; Mini App reads /miniapp-pricing. Railway Web + Worker.
# TEST_MODE=true
# TEST_PRICE_USD=1
# TEST_PRICE_SEK=10
# Optional Stripe Payment Links for simple bot.py "Buy" (no per-track metadata): only if you use bot.py
# TEST_PAYMENT_LINK_USD=https://buy.stripe.com/test_xxx
# TEST_PAYMENT_LINK_SEK=https://buy.stripe.com/test_xxx_sek
# Legacy env name (optional): if set and DEFAULT_TRACK_PRICE_USD is empty, it will be used as USD dollars
# DEFAULT_TRACK_PRICE_SEK=149
# Optional: override project root for song files (tests set this automatically)
# PROJECT_ROOT=
