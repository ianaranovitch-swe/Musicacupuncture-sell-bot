BOT_TOKEN=
# Bot logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
# Optional (Railway worker): sleep N seconds before Telegram getUpdates — reduces Conflict when old and new
# containers overlap during deploy. Try 12–20 if you see "terminated by other getUpdates" right after redeploy.
# BOT_POLLING_START_DELAY_SECONDS=15
# Telegram user id who receives /start visitor alerts (bot owner)
OWNER_TELEGRAM_ID=7846059164
# Same Telegram user id(s) pattern: developer who may run /health alongside the owner (default 7973899604)
DEVELOPER_TELEGRAM_ID=7973899604
STRIPE_SECRET_KEY=sk_live_xxx_or_sk_test_xxx
# Webhook signing secret (Stripe Dashboard). Strongly recommended for /webhook in production.
STRIPE_WEBHOOK_SECRET=whsec_xxx
BACKEND_URL=http://localhost:5000
DOMAIN=http://localhost:5000
# Telegram Mini App: полный HTTPS URL (или оставь пустым и задай только DOMAIN с https://)
# Railway (Flask): MINIAPP_URL=https://your-service.up.railway.app/miniapp.html
# GitHub Pages (только витрина): MINIAPP_URL=https://USER.github.io/REPO/miniapp.html
MINIAPP_URL=
# CORS: origins allowed to call POST /create-checkout from Mini App (comma-separated HTTPS origins).
# Example: https://yourname.github.io
MINIAPP_CORS_ORIGINS=
# Optional: same value sent in WebApp URL ?checkout_secret= and header X-Miniapp-Checkout-Secret for track_id checkouts only.
MINIAPP_CHECKOUT_SECRET=
# Stripe Checkout line amount in öre when currency=sek (default 16900 = 169 SEK).
CHECKOUT_SEK_UNIT_AMOUNT=16900

# Telegram Payments (Stripe): provider token from BotFather (needed for /buy → "Pay inside Telegram")
PAYMENTS_PROVIDER_TOKEN=
# Invoice currency for Telegram Payments (should match Stripe Checkout currency)
PAYMENTS_CURRENCY=USD
# JSON map stem/name → Telegram file_id (output of `python upload_songs.py`). Paste full JSON as one line or multiline in Railway Variables.
# Keys must match upload_songs.py (audio filename without .mp3). Do not commit real file_ids.json to Git.
# FILE_IDS_JSON={"Divine sound Vitamins from God":"AgAC..."}

# Folder under project root with audio files for sale (default: songs)
AUDIO_SALES_DIR=songs
# Default price (USD, whole dollars) for each file in that folder unless overridden in songs/catalog.json
DEFAULT_TRACK_PRICE_USD=16
# TEST_MODE: reduced prices + [TEST] labels; Mini App reads /miniapp-pricing. Railway Web + Worker.
# TEST_MODE=true
# TEST_PRICE_USD=1
# TEST_PRICE_SEK=10
# Optional Stripe Payment Links for simple bot.py "Buy" (no per-track metadata): only if you use bot.py
# TEST_PAYMENT_LINK_USD=https://buy.stripe.com/test_xxx
# TEST_PAYMENT_LINK_SEK=https://buy.stripe.com/test_xxx_sek
# Legacy env name (optional): if set and DEFAULT_TRACK_PRICE_USD is empty, it will be used as USD dollars
# DEFAULT_TRACK_PRICE_SEK=149
# Optional: override project root for song files (tests set this automatically)
# PROJECT_ROOT=
